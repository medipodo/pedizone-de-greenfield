",null,{}],["$","strong",null,{"children":"Vorteil:"}]," Kürzere Therapiedauer, hohe Erfolgsrate (",">","90%)",["$","br",null,{}],["$","strong",null,{"children":"Produktbeispiele:"}]," Lamisil®, Terbinafin-1A Pharma®"]}],["$","h3",null,{"className":"text-xl font-semibold text-medical-800 mt-6 mb-3","children":"3. Bifonazol – Langzeitwirkung"}],["$","p",null,{"className":"mb-4","children":[["$","strong",null,{"children":"Bifonazol"}]," ist ein Azol-Antimykotikum mit besonders langer Verweildauer in der Haut – ideal für Patienten, die nur einmal täglich cremen möchten."]}],["$","p",null,{"className":"mb-4","children":[["$","strong",null,{"children":"Wirkung:"}]," Fungizid und fungistatisch, 24-Stunden-Depot",["$","br",null,{}],["$","strong",null,{"children":"Anwendung:"}]," 1x täglich abends, Behandlungsdauer: 3 Wochen",["$","br",null,{}],["$","strong",null,{"children":"Vorteil:"}]," Einmal-täglich-Anwendung, gute Compliance",["$","br",null,{}],["$","strong",null,{"children":"Produktbeispiele:"}]," Bifon®, Mycospor®"]}],["$","div",null,{"className":"relative h-64 w-full my-8 rounded-xl overflow-hidden","children":["$","$L3",null,{"src":"/images/blog/creme-2.webp","alt":"Anwendung von Fußpilz Creme","fill":true,"className":"object-cover"}]}],["$","h3",null,{"className":"text-xl font-semibold text-medical-800 mt-6 mb-3","children":"4. Miconazol – Breitspektrum-Antimykotikum"}],["$","p",null,{"className":"mb-4","children":[["$","strong",null,{"children":"Miconazol"}]," wirkt nicht nur gegen Dermatophyten, sondern auch gegen Hefen und einige Bakterien."]}],["$","p",null,{"className":"mb-4","children":[["$","strong",null,{"children":"Wirkung:"}]," Breites Wirkspektrum",["$","br",null,{}],["$","strong",null,{"children":"Anwendung:"}]," 2x täglich, 2-4 Wochen",["$","br",null,{}],["$","strong",null,{"children":"Vorteil:"}]," Auch bei Mischinfektionen geeignet",["$","br",null,{}],["$","strong",null,{"children":"Produktbeispiele:"}]," Daktar®, Miconazol-ratiopharm®"]}],["$","h2