r","className":"text-primary-600 hover:underline","children":"visuellen Guide mit Bildern"}]," zeigen wir Ihnen, wie Sie die verschiedenen Typen erkennen und von anderen Hauterkrankungen unterscheiden können."]}],["$","h2",null,{"className":"text-2xl font-bold text-medical-800 mt-8 mb-4","children":"Wann sollten Sie zum Arzt gehen?"}],["$","p",null,{"className":"mb-4","children":"In vielen Fällen können Sie Fußpilz selbst behandeln. Es gibt jedoch Situationen, in denen ein Arztbesuch sinnvoll ist:"}],["$","div",null,{"className":"bg-red-50 border-l-4 border-red-500 p-6 my-6 rounded-r-lg","children":[["$","h3",null,{"className":"font-semibold text-medical-800 mb-3","children":"🚨 Arztbesuch nötig bei:"}],["$","ul",null,{"className":"space-y-2 text-medical-700 text-sm","children":[["$","li",null,{"children":"• Keine Besserung nach 2 Wochen konsequenter Selbstbehandlung"}],["$","li",null,{"children":"• Starke Schmerzen oder offene Hautstellen"}],["$","li",null,{"children":"• Verdacht auf Nagelpilz (verfärbte, verdickte Nägel)"}],["$","li",null,{"children":"• Häufiges Wiederauftreten trotz Behandlung"}],["$","li",null,{"children":"• Diabetes oder geschwächtes Immunsystem (höheres Komplikationsrisiko)"}]]}]]}],["$","p",null,{"className":"mb-4","children":"Ein Dermatologe kann die Diagnose sichern und gezielt behandeln."}],["$","h2",null,{"className":"text-2xl font-bold text-medical-800 mt-8 mb-4","children":"Häufige Fehler bei der Behandlung"}],["$","p",null,{"className":"mb-4","children":"Viele kämpfen wochenlang mit Fußpilz – oft wegen dieser typischen Fehler:"}],["$","div",null,{"className":"bg-orange-50 p-6 my-6 rounded-xl border border-orange-200","children":[["$","h3",null,{"className":"font-semibold text-medical-800 mb-4","children":"❌ Die 4 größten Fehler:"}],["$","div",null,{"className":"space-y-4 text-medical-700 text-sm","children":[["$","div",null,{"children":[["$","strong",null,{"children":"1. Zu früh aufhören"}],["$","br",null,{}],["$","span",null,{"className":"ml-5","children":"Die Symptome sind weg, aber der Pilz nicht. Mindestens 1–2 Wochen länger behandeln."}]]}],["$","div",null,{"children":[["$","strong",null,{"children":"2. Nur sichtbar behandeln"}],["$","br",null,{}],["$","span",null,{"className":"ml-5","children":"Pilz sitzt oft auch in der Umgebung. Großzügig auftragen."}]]}],["$","div",null,{"children":[["$","strong",null,{"children":"3. Feuchtigkeit ignorieren"}],["$","br",null,{}],["$","span",null,{"className":"ml-5","children":"Ohne trockene Füße keine Heilung. Nach jeder Dusche gründlich abtrocknen."}]]}],["$","div",null,{"children":[["$","strong",null,{"children":"4. Hausmittel überschätzen"}],["$","br",null,{}],["$","span",null,{"className":"ml-5","children":"Sie können unterstützen – ersetzen aber keine wirksame Therapie."}]]}]]}]]}],["$","h2",null,{"className":"text-2xl font-bold text-medical-800 mt-8 mb-4","children":"Häufige Fragen zur Behandlung"}],["$","div",null,{"className":"space-y-4 my-6","children":[["$","details",null,{"className":"group bg-white p-6 rounded-xl shadow-sm border border-medical-100","children":[["$","summary",null,{"className":"font-semibold text-medical-800 cursor-pointer flex justify-between items-center text-sm","children":["Wie behandelt man Fußpilz am effektivsten?",["$","svg",null,{"className":"w-5 h-5 text-medical-400 group-open:rotate-180 transition-transform","fill":"none","stroke":"currentColor","viewBox":"0 0 24 24","children":["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","strokeWidth":2,"d":"M19 9l-7 7-7-7"}]}]]}],["$","p",null,{"className":"mt-4 text-medical-600 text-sm","children":"Am effektivsten ist eine Kombination aus antifungaler Creme (z.B. Clotrimazol oder Terbinafin) und konsequenter Hygiene. Wichtig ist, die Behandlung regelmäßig durchzuführen und nicht zu früh abzubrechen – auch wenn die Symptome bereits verschwunden sind."}]]}],["$","details",null,{"className":"group bg-white p-6 rounded-xl shadow-sm border border-medical-100","children":[["$","summary",null,{"className":"font-semibold text-medical-800 cursor-pointer flex justify-between items-center text-sm","children":["Kann Fußpilz von alleine verschwinden?",["$","svg",null,{"className":"w-5 h-5 text-medical-400 group-open:rotate-180 transition-transform","fill":"none","stroke":"currentColor","viewBox":"0 0 24 24","children":["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","strokeWidth":2,"d":"M19 9l-7 7-7-7"}]}]]}],["$","p",null,{"className":"mt-4 text-medical-600 text-sm","children":"In der Regel nicht. Ohne Behandlung breitet sich die Infektion oft weiter aus. In seltenen Fällen können Symptome vorübergehend verschwinden, kommen aber meist zurück – oft stärker als zuvor."}]]}],["$","details",null,{"className":"group bg-white p-6 rounded-xl shadow-sm border border-medical-100","children":[["$","summary",null,{"className":"font-semibold text-medical-800 cursor-pointer flex justify-between items-center text-sm","children":["Welche Creme ist die beste gegen Fußpilz?",["$","svg",null,{"className":"w-5 h-5 text-medical-400 group-open:rotate-180 transition-transform","fill":"none","stroke":"currentColor","viewBox":"0 0 24 24","children":["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","strokeWidth":2,"d":"M19 9l-7 7-7-7"}]}]]}],["$","p",null,{"className":"mt-4 text-medical-600 text-sm","children":"Es gibt keine \"eine beste\" Creme. Wirkstoffe wie Clotrimazol, Bifonazol oder Terbinafin gelten als bewährt und sind in vielen Präparaten enthalten. Terbinafin wirkt oft schneller, ist aber teurer. Entscheidend ist die konsequente Anwendung über mehrere Wochen."}]]}],["$","details",null,{"className":"group bg-white p-6 rounded-xl shadow-sm border border-medical-100","children":[["$","summary",null,{"className":"font-semibold text-medical-800 cursor-pointer flex justify-between items-center text-sm","children":["Ist Fußpilz während der Behandlung ansteckend?",["$","svg",null,{"className":"w-5 h-5 text-medical-400 g